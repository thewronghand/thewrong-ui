{
  "name": "@thewrong/ui",
  "version": "0.2.0",
  "description": "@thewronghand의 개인 프로젝트용 React UI 컴포넌트 라이브러리",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./hooks": {
      "types": "./dist/src/hooks/index.d.ts",
      "import": "./dist/hooks.esm.js",
      "require": "./dist/hooks.cjs.js"
    },
    "./styles.css": "./dist/ui.css"
  },
  "files": [
    "dist",
    "llms.txt"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "vite build",
    "build:storybook": "storybook build",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "@dnd-kit/core": ">=6",
    "@dnd-kit/sortable": ">=10",
    "@dnd-kit/utilities": ">=3",
    "@floating-ui/react": ">=0.26",
    "@tanstack/react-virtual": ">=3",
    "date-fns": ">=3",
    "motion": ">=11",
    "react": ">=18",
    "react-dom": ">=18",
    "react-hot-toast": ">=2"
  },
  "peerDependenciesMeta": {
    "motion": {
      "optional": true
    },
    "@floating-ui/react": {
      "optional": true
    },
    "react-hot-toast": {
      "optional": true
    },
    "@dnd-kit/core": {
      "optional": true
    },
    "@dnd-kit/sortable": {
      "optional": true
    },
    "@dnd-kit/utilities": {
      "optional": true
    },
    "@tanstack/react-virtual": {
      "optional": true
    },
    "date-fns": {
      "optional": true
    }
  },
  "keywords": [
    "ui",
    "react",
    "components",
    "tailwindcss",
    "design-system"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thewronghand/thewrong-ui.git"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@eslint/js": "^9.39.4",
    "@floating-ui/react": "^0.27.19",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-virtual": "^3.14.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "date-fns": "^4.4.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.6.0",
    "motion": "^12.40.0",
    "playwright": "^1.60.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hot-toast": "^2.6.0",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "use-debounce": "^10.1.1",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "tailwind-merge": "^3.6.0"
  }
}
