{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "declaration": true,
    "emitDeclarationOnly": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  // stories도 타입체크 대상 — props 오타가 빌드까지 새는 걸 막는다.
  // (dts 산출물에서의 제외는 vite.config dts exclude가 담당)
  "include": ["src", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
